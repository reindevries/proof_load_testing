{
    "version": "0.2.0",
    "configurations": [
        //
        // Debug
        //
        {
            "name": "Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}\\${fileBasenameNoExtension}.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "${env:USERPROFILE}\\msys64\\mingw64\\bin\\gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Set Disassembly Flavor to Intel",
                    "text": "-gdb-set disassembly-flavor intel",
                    "ignoreFailures": true
                },
                {
                    "description": "Ensures that a breakpoint for abort will be set!",
                    "text": "set breakpoint pending on",
                    "ignoreFailures": true
                },
                {
                    "description": "Breaks on failed asserts",
                    "text": "break abort",
                    "ignoreFailures": true
                },
                {
                    "description": "Setting back to default behaviour",
                    "text": "set breakpoint pending auto",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Debug"
        },
        //
        // Release
        //
        {
            "name": "Release",
            "type": "f5anything",
            "request": "launch",
            "command": "cd '${workspaceFolder}'; & .\\${fileBasenameNoExtension}.exe",
            "preLaunchTask": "Build Release"
        }
    ]
}