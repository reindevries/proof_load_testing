{
    "tasks": [
        //
        // Debug
        //
        {
            "type": "cppbuild",
            "label": "Build Debug",
            "command": "g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-Wall",
                "-Wno-sign-compare",
                "-std=c++17",
                "-DDEBUG",
                "-D_DEBUG",
                "-g",
                "-march=native",
                "-fopenmp",
                "-I", "%USERPROFILE%\\cpp_include",
                "${fileBasenameNoExtension}.cpp",
                "-o", "${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Debug Task"
        },
        //
        // Release
        //
        {
            "type": "cppbuild",
            "label": "Build Release",
            "command": "g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-Wall",
                "-Wno-sign-compare",
                "-std=c++17",
                "-DNDEBUG",
                "-O3",
                "-march=native",
                "-fopenmp",
                "-I", "%USERPROFILE%\\cpp_include",
                "${fileBasenameNoExtension}.cpp",
                "-o", "${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "detail": "Release Task"
        }
    ],
    "version": "2.0.0"
}